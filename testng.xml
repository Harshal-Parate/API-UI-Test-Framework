<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="tests" thread-count="${threads}">

    <parameter name="env" value="${env}"/>
    <parameter name="browser" value="${browser}"/>

    <listeners>
        <listener class-name="org.example.listeners.TestListener"/>
        <listener class-name="org.example.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="Login Tests">

        <classes>
            <class name="org.example.tests.LoginTest"/>
        </classes>

    </test>

</suite>